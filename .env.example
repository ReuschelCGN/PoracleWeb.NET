# Database (Poracle MySQL)
DB_HOST=host.docker.internal
DB_PORT=3309
DB_NAME=poracle
DB_USER=root
DB_PASSWORD=your_db_password

# PoracleWeb DB (separate database for app-owned data: user geofences, etc.)
# This database is NOT the Poracle DB — it is created/managed by PoracleWeb.
# Create the database manually: CREATE DATABASE poracle_web; — tables are auto-created on startup.
WEB_DB_HOST=host.docker.internal
WEB_DB_PORT=3309
WEB_DB_NAME=poracle_web
WEB_DB_USER=root
WEB_DB_PASSWORD=your_db_password

# Scanner DB (optional - RDM)
# SCANNER_DB_CONNECTION=Server=host.docker.internal;Port=3391;Database=rdmdb;User=root;Password=your_password

# JWT Secret (minimum 32 characters)
JWT_SECRET=generate-a-long-random-secret-key-at-least-32-chars

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token
# Discord forum channel ID for geofence submission threads (optional).
# When set, new geofence submissions create a forum post with status tags (Pending/Approved/Rejected).
DISCORD_GEOFENCE_FORUM_CHANNEL_ID=

# Telegram (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Poracle API
PORACLE_API_ADDRESS=http://host.docker.internal:3030
PORACLE_API_SECRET=your_poracle_api_secret

# Admin User IDs (comma-separated Discord/Telegram user IDs)
PORACLE_ADMIN_IDS=your_discord_user_id

# Poracle Multi-Server Restart (optional)
# Configure each server with Name, Host (SSH hostname/IP), ApiAddress, and SshUser.
# Servers are indexed starting at 0. Set as many as needed.
# PORACLE_SERVER_1_HOST=192.168.1.10
# PORACLE_SERVER_1_API=http://192.168.1.10:3030
# PORACLE_SERVER_1_SSH_USER=root
# PORACLE_SERVER_2_HOST=192.168.1.11
# PORACLE_SERVER_2_API=http://192.168.1.11:3030
# PORACLE_SERVER_2_SSH_USER=root
# SSH_KEY_PATH=./data/ssh_key
# PORACLE_SSH_KEY_PATH=/app/ssh_key

# Koji Geofence API (required for custom geofences feature)
# Used for: fetching regions, promoting approved geofences to public areas.
# PoracleWeb serves ALL geofences (admin from Koji + user from DB) via /api/geofence-feed.
# PoracleJS geofence.path should point to PoracleWeb only:
#   e.g., "http://poracleweb:8082/api/geofence-feed"
KOJI_API_ADDRESS=http://localhost:8080
KOJI_BEARER_TOKEN=your_koji_bearer_token
# Koji project ID — the project where approved/public geofences are stored
KOJI_PROJECT_ID=1
# Koji project name — used to fetch geofences in Poracle format from the /geofence/poracle/{name} endpoint
KOJI_PROJECT_NAME=YourProjectName

# Poracle config directory (for DTS template previews)
# Mount the PoracleJS config directory so DTS files are auto-loaded
# Example: /source/PoracleJS/config
PORACLE_CONFIG_DIR=/path/to/PoracleJS/config
